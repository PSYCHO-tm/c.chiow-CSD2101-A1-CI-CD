#version 300 es
precision mediump float;

in vec4 TriangleColor;
out vec4 FragColor;

void main()
{
    FragColor = TriangleColor;
}
#version 300 es
layout(location = 0) in vec4 VertexPosition;
layout(location = 1) in vec4 VertexColor;

uniform float RadianAngle;

out vec4 TriangleColor;

void main()
{
    float c = cos(RadianAngle);
    float s = sin(RadianAngle);

    // 2D rotation matrix applied to XY, Z and W pass through
    vec2 rotated = mat2(c, s, -s, c) * VertexPosition.xy;
    gl_Position   = vec4(rotated, 0.0, 1.0);
    TriangleColor = VertexColor;
}
#version 300 es
precision mediump float;

in  vec4 SquareColor;
out vec4 FragColor;

void main()
{
    FragColor = SquareColor;
}
#version 300 es
layout(location = 0) in vec2 VertexPosition;
layout(location = 1) in vec3 VertexColor;

out vec4 SquareColor;

void main()
{
    gl_Position = vec4(VertexPosition, 0.0, 1.0);
    SquareColor = vec4(VertexColor, 1.0);
}
